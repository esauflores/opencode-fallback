{
  "ignorePatterns": ["dist", "node_modules", "bun.lock"],
  "env": {
    "node": true,
    "es2022": true
  },
  "globals": {
    "AbortController": "readonly",
    "AbortSignal": "readonly",
    "Buffer": "readonly",
    "clearTimeout": "readonly",
    "fetch": "readonly",
    "RequestInit": "readonly",
    "Response": "readonly",
    "setTimeout": "readonly",
    "URL": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error"
  }
}
